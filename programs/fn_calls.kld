// EXPECTS 8

fn add(x: i32, y: i32) -> i32 {
    return x + y;
}

fn sub(x: i32, y: i32) -> i32{
    return x - y;
}

// Functions without a type specifier are assumed to return void
fn test() {
    let a: i32 = add(1, 1);
    return;
}

fn main(){
    test();
    sub(1, 1);
    return add(1, 3) + sub(5, 1);
}
